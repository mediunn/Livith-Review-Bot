# 봇 설정 템플릿 — 복사해서 .env 만들고 실제 값 채우기 (.env는 커밋 안 됨)
# 실제 시크릿(토큰)은 Hermes가 ~/.hermes 에 보관한다. 여기 토큰 항목은 참고/이식용.

# ── Notion ──────────────────────────────────────────
NOTION_TOKEN=                 # 통합 토큰 (ntn_...) — DB 조회용
NOTION_PRD_PAGE_ID=           # 7차 PRD 페이지 ID
NOTION_REQ_DB3_ID=            # 필수 요구사항(3) 데이터소스 ID (캘린더+알림)
NOTION_REQ_DB4_ID=            # 필수 요구사항(4) 데이터소스 ID (인스타 파싱)

# ── Figma ───────────────────────────────────────────
FIGMA_API_KEY=                # 개인 액세스 토큰 (figd_...)
FIGMA_FILE_KEY=               # 7차 와이어프레임 파일 key
FIGMA_DEFAULT_NODE=           # 기본 진입 노드 (예: 3022-16008)

# ── Discord (게이트웨이) ─────────────────────────────
DISCORD_BOT_TOKEN=            # 봇 토큰
